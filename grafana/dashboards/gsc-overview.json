{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Clicks (Latest Day)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "noValue": "No data"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "last_over_time(gsc_clicks{site=\"musick.com.au\"}[3d])", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Impressions (Latest Day)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "noValue": "No data"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "last_over_time(gsc_impressions{site=\"musick.com.au\"}[3d])", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "CTR (Latest Day)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "green", "value": 0.04 }
            ]
          },
          "noValue": "No data"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "last_over_time(gsc_ctr{site=\"musick.com.au\"}[3d])", "refId": "A" }]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Avg Position (Latest Day)",
      "description": "Lower is better — position 1 = top result",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 30 }
            ]
          },
          "noValue": "No data"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "last_over_time(gsc_position{site=\"musick.com.au\"}[3d])", "refId": "A" }]
    },

    {
      "type": "row",
      "id": 101,
      "title": "Trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Clicks & Impressions",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "always", "pointSize": 6 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Impressions" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "targets": [
        { "expr": "gsc_clicks{site=\"musick.com.au\"}", "legendFormat": "Clicks", "refId": "A" },
        { "expr": "gsc_impressions{site=\"musick.com.au\"}", "legendFormat": "Impressions", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "CTR & Average Position",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "always", "pointSize": 6 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CTR" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "Position" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "targets": [
        { "expr": "gsc_ctr{site=\"musick.com.au\"}", "legendFormat": "CTR", "refId": "A" },
        { "expr": "gsc_position{site=\"musick.com.au\"}", "legendFormat": "Position", "refId": "B" }
      ]
    },
    {
      "type": "bargauge",
      "id": 7,
      "title": "Top Pages by Impressions",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [{
        "expr": "topk(10, last_over_time(gsc_page_impressions{site=\"musick.com.au\"}[3d]))",
        "legendFormat": "{{page}}",
        "instant": true,
        "refId": "A"
      }]
    },

    {
      "type": "row",
      "id": 102,
      "title": "Top Queries",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "type": "table",
      "id": 8,
      "title": "Top Queries — Clicks, Impressions & Position",
      "gridPos": { "h": 12, "w": 15, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Clicks" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Impressions" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Position" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Clicks", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "last_over_time(gsc_query_clicks{site=\"musick.com.au\"}[3d])",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "last_over_time(gsc_query_impressions{site=\"musick.com.au\"}[3d])",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d])",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "site": true },
            "renameByName": {
              "query": "Query",
              "Value #A": "Clicks",
              "Value #B": "Impressions",
              "Value #C": "Position"
            },
            "indexByName": { "Query": 0, "Clicks": 1, "Impressions": 2, "Position": 3 }
          }
        }
      ]
    },
    {
      "type": "bargauge",
      "id": 9,
      "title": "Position Distribution",
      "description": "Count of tracked queries at each ranking tier",
      "gridPos": { "h": 12, "w": 9, "x": 15, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Position 1–3" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Position 4–10" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Position 11–20" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Position 21+" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "text": {}
      },
      "targets": [
        {
          "expr": "count(last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) <= 3)",
          "legendFormat": "Position 1–3",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "count(last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) > 3 and last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) <= 10)",
          "legendFormat": "Position 4–10",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "count(last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) > 10 and last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) <= 20)",
          "legendFormat": "Position 11–20",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "count(last_over_time(gsc_query_position{site=\"musick.com.au\"}[3d]) > 20)",
          "legendFormat": "Position 21+",
          "instant": true,
          "refId": "D"
        }
      ]
    },

