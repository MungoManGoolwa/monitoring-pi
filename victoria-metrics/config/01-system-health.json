{"title":"System Health Overview","rows":[{"panels":[{"title":"System CPU Usage %","width":6,"expr":["100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"]},{"title":"System Memory Usage %","width":6,"expr":["(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100"]},{"title":"System Load Average","width":6,"expr":["node_load1","node_load5","node_load15"]},{"title":"Filesystem Usage %","width":6,"expr":["100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)"]},{"title":"Disk Read Throughput","width":6,"expr":["sum by(instance)(rate(node_disk_read_bytes_total[5m]))"]},{"title":"Disk Write Throughput","width":6,"expr":["sum by(instance)(rate(node_disk_written_bytes_total[5m]))"]},{"title":"Network Received (bytes/s)","width":6,"expr":["sum by(instance)(rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br.*|veth.*\"}[5m]))"]},{"title":"Network Transmitted (bytes/s)","width":6,"expr":["sum by(instance)(rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br.*|veth.*\"}[5m]))"]}]}]}
