{"title":"MySQL Performance","rows":[{"panels":[{"title":"MySQL Threads Connected","width":6,"expr":["mysql_global_status_threads_connected"]},{"title":"MySQL Queries per Second","width":6,"expr":["rate(mysql_global_status_queries[5m])"]},{"title":"MySQL Slow Queries","width":6,"expr":["rate(mysql_global_status_slow_queries[5m])"]},{"title":"MySQL Bytes Received/Sent","width":6,"expr":["rate(mysql_global_status_bytes_received[5m])","rate(mysql_global_status_bytes_sent[5m])"]},{"title":"InnoDB Buffer Pool Hit Rate %","width":6,"expr":["100 - (rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m]) * 100)"]},{"title":"MySQL Table Locks Waited","width":6,"expr":["rate(mysql_global_status_table_locks_waited[5m])"]}]}]}
